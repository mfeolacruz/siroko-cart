# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================

# Database Configuration
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=siroko_cart
MYSQL_USER=siroko
MYSQL_PASSWORD=siroko123
MYSQL_PORT=3306

# Docker Ports
NGINX_PORT=8081
MYSQL_EXTERNAL_PORT=3306
REDIS_PORT=6379

# PHP Configuration
PHP_MEMORY_LIMIT=256M
PHP_MAX_EXECUTION_TIME=30

# Xdebug Configuration
XDEBUG_MODE=debug,coverage
XDEBUG_CLIENT_HOST=host.docker.internal
XDEBUG_CLIENT_PORT=9003

# =============================================================================
# SYMFONY CONFIGURATION
# =============================================================================

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=your_secret_key_here_change_in_production
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
DATABASE_URL=mysql://siroko:siroko123@mysql:3306/siroko_cart
# For SQLite tests
DATABASE_TEST_URL=sqlite:///%kernel.project_dir%/var/test.db
###< doctrine/doctrine-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost:8081
###< symfony/routing ###